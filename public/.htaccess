# SPA routing for cPanel/Apache — serve real files, otherwise fall back to index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't touch existing files or directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else -> the SPA shell (client-side router takes over)
  RewriteRule ^ index.html [L]
</IfModule>

# Long-cache fingerprinted assets; never cache the HTML shell or the service worker
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "(index\.html|sw\.js|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
  # Security headers (defense-in-depth for static SPA hosting)
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # Force HTTPS for 2 years incl. subdomains (only takes effect once served over TLS)
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  # Content-Security-Policy: allow only known origins. Tailwind/React need inline
  # styles; the Zoom Web SDK needs wasm + its CDN/api; Supabase needs REST+realtime;
  # Google is the OAuth provider. Tighten further if a dependency is dropped.
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; img-src 'self' data: blob: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval' https://source.zoom.us https://*.zoom.us; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.zoom.us wss://*.zoom.us https://accounts.google.com; frame-src 'self' https://*.zoom.us https://accounts.google.com; worker-src 'self' blob:; manifest-src 'self'"
</IfModule>
