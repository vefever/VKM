{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "misty-salad-5cf6",
  "compatibility_date": "2026-06-30",
  "observability": {
    "enabled": true
  },
  "main": "@tanstack/react-start/server-entry",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "SUPABASE_URL": "https://ehsbzxrekrhmmpvbxlfv.supabase.co",
    "SUPABASE_PUBLISHABLE_KEY": "sb_publishable_IoF8xSRS0zdq9lJhM3evzQ_qvJr9_KH",
    "SUPABASE_PROJECT_ID": "ehsbzxrekrhmmpvbxlfv",
    "VITE_SUPABASE_URL": "https://ehsbzxrekrhmmpvbxlfv.supabase.co",
    "VITE_SUPABASE_PUBLISHABLE_KEY": "sb_publishable_IoF8xSRS0zdq9lJhM3evzQ_qvJr9_KH",
    "VITE_SUPABASE_PROJECT_ID": "ehsbzxrekrhmmpvbxlfv",
    // AI Business Advisor provider. Lets the advisor work without the DB/service
    // role. The admin panel (Admin → AI Configurations) still overrides this when
    // the worker can read the DB. AI_API_KEY is intentionally NOT here — it's a
    // Cloudflare secret: set/rotate it with `wrangler secret put AI_API_KEY`.
    "AI_PROVIDER": "anthropic",
    "AI_BASE_URL": "https://opus.abhibots.com/v1",
    "AI_MODEL": "claude-sonnet-4-6",
    "AI_MAX_TOKENS": "1024"
  }
}
